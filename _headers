# Service worker must always revalidate so new versions ship immediately
/service-worker.js
  Cache-Control: public, max-age=0, must-revalidate

# HTML pages: revalidate on every request (prevents stale homepage)
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Versioned static assets can be cached aggressively (we bust via ?v=N)
/*.css
  Cache-Control: public, max-age=31536000
/*.js
  Cache-Control: public, max-age=31536000
/icons/*
  Cache-Control: public, max-age=31536000, immutable
/icon.svg
  Cache-Control: public, max-age=31536000, immutable
